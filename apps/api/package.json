    "@swc/core": "^1.10.0",
    "@swc/helpers": "^0.5.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
