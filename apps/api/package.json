  "type": "module",
  "scripts": {
    "db:generate": "prisma generate --config prisma.config.ts --schema ./prisma/schema.prisma",
    "db:push": "prisma  db push --config prisma.config.ts --schema ./prisma/schema.prisma",
    "db:reset": "prisma db push --force-reset --config prisma.config.ts --schema ./prisma/schema.prisma",
    "db:studio": "prisma  studio ",
    "build": "nest build && tsc-alias -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
