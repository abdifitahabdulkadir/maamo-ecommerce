
generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}


model User {
 id String @id @default(uuid())
 createdAt DateTime @default(now() )
 updatedAt DateTime @updatedAt

 name String
 email String
 gender String
 account Account[]
 @@index([id])
}


model Account {
id String @id @default(uuid())
createdAt DateTime @default(now() )
updatedAt DateTime @updatedAt

providerId String
accountId String

password String
accessToken String
refereshToken String
accessTokenExpirationAt DateTime
refereshTokenExpirationAt DateTime

userId String
user User @relation(fields: [userId], references: [id], onDelete: Cascade)

@@index([userId])
}
